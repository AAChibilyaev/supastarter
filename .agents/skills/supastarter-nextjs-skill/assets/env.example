# supastarter Next.js — environment template (mirrors .env.local.example from the repo)
# Copy to .env.local for app dev. ALSO copy to .env so Prisma scripts pick it up.
# Do not commit secrets.

# ─── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=
# For local dev with the docker-compose stack:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/supastarter"
# Some hosts (Supabase) need a separate direct URL for migrations:
DIRECT_URL=

# ─── App URLs (split apps) ─────────────────────────────────────────────────
NEXT_PUBLIC_MARKETING_URL="http://localhost:3001"
NEXT_PUBLIC_SAAS_URL="http://localhost:3000"
NEXT_PUBLIC_DOCS_URL="http://localhost:3002"

# ─── Authentication (Better Auth) ──────────────────────────────────────────
BETTER_AUTH_SECRET=
# Generate: openssl rand -base64 32
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Mail ──────────────────────────────────────────────────────────────────
MAIL_FROM="noreply@example.com"
# Nodemailer (SMTP)
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
# Or one of: Plunk / Resend / Postmark / Mailgun
PLUNK_API_KEY=
RESEND_API_KEY=
POSTMARK_SERVER_TOKEN=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ─── Payments (pick one provider) ─────────────────────────────────────────
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
DODO_PAYMENTS_API_KEY=

# Product / price IDs (server-only — do not expose to client)
PRICE_ID_PRO_MONTHLY=
PRICE_ID_PRO_YEARLY=
PRICE_ID_LIFETIME=

# ─── Analytics (client-exposed) ────────────────────────────────────────────
NEXT_PUBLIC_PIRSCH_CODE=
NEXT_PUBLIC_PLAUSIBLE_URL=
NEXT_PUBLIC_MIXPANEL_TOKEN=
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# ─── Storage (S3-compatible) ───────────────────────────────────────────────
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_REGION=
NEXT_PUBLIC_AVATARS_BUCKET_NAME="avatars"
# Local MinIO defaults from docker-compose:
# S3_ACCESS_KEY_ID="minioadmin"
# S3_SECRET_ACCESS_KEY="minioadmin"
# S3_ENDPOINT="http://localhost:9000"
# S3_REGION="us-east-1"

# ─── AI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Add other provider keys as needed (ANTHROPIC_API_KEY, etc.)
