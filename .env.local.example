# ============================================================
# PRODUCTION REQUIRED VARIABLES — app will not start without:
#   DATABASE_URL, NEXT_PUBLIC_SAAS_URL, NEXT_PUBLIC_MARKETING_URL,
#   BETTER_AUTH_SECRET, one mail provider, Typesense vars.
# ============================================================

# Database
# REQUIRED IN PRODUCTION
DATABASE_URL="YOUR_DATABASE_CONNECTION_STRING"
# For local development with Docker Compose:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/supastarter"
# ... if you use Supabase
DIRECT_URL=""

# App URLs (used for absolute URLs, sitemaps, auth callbacks, etc.)
# REQUIRED IN PRODUCTION — set to your actual domain(s)
NEXT_PUBLIC_MARKETING_URL="http://localhost:3001"
NEXT_PUBLIC_SAAS_URL="http://localhost:3000"

# Docs url
NEXT_PUBLIC_DOCS_URL="http://localhost:3001"

# Authentication
# REQUIRED IN PRODUCTION — use a strong random secret (openssl rand -base64 32)
BETTER_AUTH_SECRET="A_RANDOM_SECRET_STRING"
# Comma-separated list of trusted origins for cross-origin auth requests.
# REQUIRED IN PRODUCTION when your domain differs from NEXT_PUBLIC_SAAS_URL
# or when you serve from multiple origins (e.g. preview deployments, custom domains).
# Example: "https://app.example.com,https://preview.example.com"
BETTER_AUTH_TRUSTED_ORIGINS=""
# ... for Github
GITHUB_CLIENT_ID="YOUR_GITHUB_CLIENT_ID"
GITHUB_CLIENT_SECRET="YOUR_GITHUB_CLIENT_SECRET"
# ... for Google
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# Mails
MAIL_FROM="noreply@example.com"
# ... with nodemailer
MAIL_HOST=""
MAIL_PORT=""
MAIL_USER=""
MAIL_PASS=""
# ... with Plunk
PLUNK_API_KEY=""
# ... with Resend
RESEND_API_KEY=""
# ... with Postmark
POSTMARK_SERVER_TOKEN=""
# ... with Mailgun
MAILGUN_API_KEY=""
MAILGUN_DOMAIN=""

# Payments
# ... with Lemonsqueezy
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_WEBHOOK_SECRET=""
LEMONSQUEEZY_STORE_ID=""
# ... with Stripe
STRIPE_SECRET_KEY=***
STRIPE_WEBHOOK_SECRET=***
STRIPE_AUTOMATIC_TAX=false   # set to true after Stripe Tax registration
# ... with Creem
CREEM_API_KEY=""
CREEM_WEBHOOK_SECRET=""
# ... with Polar
POLAR_ACCESS_TOKEN=""
POLAR_WEBHOOK_SECRET=""
# ... with DodoPayments
DODO_PAYMENTS_API_KEY=""

# Product price ids
PRICE_ID_PRO_MONTHLY="price_asdf1234"
PRICE_ID_PRO_YEARLY="price_asdf1234"
PRICE_ID_LIFETIME="price_asdf1234"

# Sentry — error tracking & monitoring
# DSN is the same value for both vars; NEXT_PUBLIC_ is used client-side
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
# Sentry organisation / project slugs (from sentry.io)
SENTRY_ORG=""
SENTRY_PROJECT=""
# Auth token for source-map upload during CI builds (keep server-only)
SENTRY_AUTH_TOKEN=""
# Environment tag sent with every event ("development" | "staging" | "production")
SENTRY_ENVIRONMENT="development"
NEXT_PUBLIC_SENTRY_ENVIRONMENT="development"

# Analytics
# ... for Pirsch
NEXT_PUBLIC_PIRSCH_CODE=""
# ... for Plausible
NEXT_PUBLIC_PLAUSIBLE_URL=""
# ... for Mixpanel
NEXT_PUBLIC_MIXPANEL_TOKEN=""
# ... for Google Analytics
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=""

# Storage
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""
S3_REGION=""
NEXT_PUBLIC_AVATARS_BUCKET_NAME="avatars"
# For local development with Docker Compose (MinIO):
# S3_ACCESS_KEY_ID="minioadmin"
# S3_SECRET_ACCESS_KEY="minioadmin"
# S3_ENDPOINT="http://localhost:9000"
# S3_REGION="us-east-1"

# AI
# ... with OpenAI
OPENAI_API_KEY=""

# Search (Typesense) — REQUIRED IN PRODUCTION; admin key MUST stay server-only, never NEXT_PUBLIC_
TYPESENSE_HOST="localhost"
TYPESENSE_PORT="8108"
TYPESENSE_PROTOCOL="http"
TYPESENSE_ADMIN_API_KEY="xyz_change_me_in_production"
# Bearer secret for POST /api/cron/search-flush (called by trigger.dev/QStash/Vercel Cron)
SEARCH_CRON_SECRET=""
# Bearer secret for wallet/billing cron endpoints
# (expire-reservations, reconcile-tochka-topups, sync-subscriptions)
WALLET_CRON_SECRET=***

# Tochka (Russian acquiring bank) — AI wallet top-ups
# TOCHKA_API_BASE_URL="https://enter.tochka.com/sandbox"
# TOCHKA_API_BASE_URL="https://enter.tochka.com"  # production
TOCHKA_API_BASE_URL="https://enter.tochka.com/sandbox"
TOCHKA_JWT_TOKEN=***
TOCHKA_CUSTOMER_CODE=***
TOCHKA_MERCHANT_ID=***
TOCHKA_WEBHOOK_PUBLIC_KEY="***"
