{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["typescript", "react", "import", "jsx-a11y", "oxc"],
	"ignorePatterns": [
		"**/.content-collections/**",
		"**/prisma/zod/index.ts",
		"packages/loadtest/**",
		"**/*.cjs",
		"**/*.mjs",
		"modules/wordpress/**",
		"**/public/**/*.js",
		"apps/saas/public/**"
	],
	"options": {
		"typeAware": true
	},
	"overrides": [
		{
			"files": [
				"packages/ui/components/**",
				"apps/saas/modules/shared/components/**",
				"apps/saas/modules/organizations/components/**"
			],
			"rules": {
				"no-redundant-type-constituents": "off"
			}
		}
	]
}
