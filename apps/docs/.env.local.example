# ── AACSearch Dogfood Configuration ───────────────────────────
# AACSearch API base URL (same as SaaS app URL)
NEXT_PUBLIC_AACSEARCH_BASE_URL="http://localhost:3010"

# Search-only API key (ss_search_*) — embedded in browser for search queries
NEXT_PUBLIC_AACSEARCH_SEARCH_KEY=""

# Docs index slug — created by the ingest script
NEXT_PUBLIC_AACSEARCH_DOCS_INDEX_SLUG="docs"

# Admin API key (aa_admin_*) — used by build-time ingest script (server-only)
AACSEARCH_ADMIN_KEY=""
