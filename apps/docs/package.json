{
	"name": "docs",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"build": "node --import tsx scripts/generate-api-ref.ts && node --import tsx scripts/generate-changelog.ts && next build",
		"clean": "git clean -xdf .cache .turbo dist node_modules .next .source",
		"dev": "next dev --port 3002",
		"start": "next start",
		"type-check": "node --import tsx scripts/generate-api-ref.ts && node --import tsx scripts/generate-changelog.ts && next typegen && fumadocs-mdx && tsc --noEmit",
		"postinstall": "node --import tsx scripts/generate-api-ref.ts && fumadocs-mdx",
		"lint": "oxlint .",
		"format": "oxfmt .",
		"ingest:docs": "node --import tsx scripts/generate-api-ref.ts && fumadocs-mdx && node --import tsx scripts/ingest-docs.ts",
		"generate:changelog": "node --import tsx scripts/generate-changelog.ts",
		"generate:api-ref": "node --import tsx scripts/generate-api-ref.ts"
	},
	"dependencies": {
		"@repo/tailwind-config": "workspace:*",
		"@repo/ui": "workspace:*",
		"fumadocs-core": "16.8.5",
		"fumadocs-mdx": "14.2.11",
		"fumadocs-openapi": "^10.6.8",
		"fumadocs-ui": "16.8.5",
		"lucide-react": "catalog:",
		"next": "^16.2.2",
		"react": "catalog:",
		"react-dom": "catalog:",
		"tailwind-merge": "catalog:"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "catalog:",
		"@types/mdx": "catalog:",
		"@types/node": "^25.5.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "catalog:",
		"postcss": "catalog:",
		"tailwindcss": "catalog:",
		"typescript": "catalog:"
	}
}
