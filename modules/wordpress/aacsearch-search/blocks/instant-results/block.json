{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "aacsearch/instant-results",
    "title": "AACsearch Instant Results",
    "category": "widgets",
    "icon": "grid-view",
    "description": "AACsearch search results grid with filters, sorting, and pagination.",
    "keywords": ["search", "results", "aacsearch", "grid"],
    "version": "1.0.0",
    "textdomain": "aacsearch-search",
    "editorScript": "file:./index.js",
    "attributes": {
        "postTypes": {
            "type": "string",
            "default": ""
        },
        "columns": {
            "type": "number",
            "default": 3
        },
        "perPage": {
            "type": "number",
            "default": 10
        },
        "showFacets": {
            "type": "boolean",
            "default": true
        },
        "showSort": {
            "type": "boolean",
            "default": true
        }
    },
    "supports": {
        "html": false,
        "align": ["wide", "full"],
        "color": {
            "background": true,
            "text": true
        },
        "spacing": {
            "margin": true,
            "padding": true
        }
    }
}
