{
	"name": "supastarter-nextjs",
	"private": true,
	"scripts": {
		"build": "dotenv -c -- turbo build",
		"dev": "dotenv -c -- turbo dev --concurrency 15",
		"generate:openapi": "pnpm exec tsx packages/api/scripts/generate-openapi.ts",
		"type-check": "dotenv -c -- turbo type-check",
		"start": "dotenv -c -- turbo start",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix .",
		"clean": "turbo clean",
		"test": "dotenv -c -- turbo test",
		"format": "oxfmt .",
		"format:check": "oxfmt --check .",
		"validate:openapi": "redocly lint packages/api/openapi.yaml"
	},
	"dependencies": {
		"@base-ui/react": "^1.4.1",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/react-virtual": "^3.13.24",
		"@types/papaparse": "^5.5.2",
		"oxlint-tsgolint": "^0.20.0",
		"papaparse": "^5.5.3"
	},
	"devDependencies": {
		"@redocly/cli": "^2.30.3",
		"@repo/tsconfig": "workspace:*",
		"@types/node": "catalog:",
		"dotenv-cli": "catalog:",
		"oxfmt": "catalog:",
		"oxlint": "catalog:",
		"tsx": "catalog:",
		"turbo": "^2.9.4",
		"typescript": "catalog:"
	},
	"engines": {
		"node": ">=20"
	},
	"packageManager": "pnpm@10.28.2",
	"pnpm": {
		"onlyBuiltDependencies": [
			"@parcel/watcher",
			"@prisma/client",
			"@prisma/engines",
			"@swc/core",
			"esbuild",
			"prisma",
			"prisma-zod-generator",
			"sharp"
		],
		"overrides": {
			"next-themes": "npm:@teispace/next-themes@0.3.2"
		}
	}
}
