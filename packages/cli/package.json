    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "12.1.0",
    "conf": "13.1.0",
    "open": "10.1.0",
    "@repo/logs": "workspace:*"
  },
  "devDependencies": {
    "@repo/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
