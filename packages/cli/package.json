{
  "name": "aacsearch",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "AACsearch CLI — npx aacsearch",
  "bin": {
    "aacsearch": "./bin/aacsearch.mjs"
  },
  "files": ["dist", "bin"],
