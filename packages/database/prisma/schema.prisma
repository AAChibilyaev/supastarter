datasource db {
  provider = "postgresql"
}

generator client {
  provider   = "prisma-client"
  output     = "./generated"
  engineType = "client"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "./zod"
  config   = "./zod-generator.config.json"
}

model User {
  id                       String                       @id @default(cuid())
  name                     String
  email                    String
  emailVerified            Boolean
  image                    String?
  createdAt                DateTime
  updatedAt                DateTime
  username                 String?
  role                     String?
  banned                   Boolean?
  banReason                String?
  banExpires               DateTime?
  onboardingComplete       Boolean                      @default(false)
  dripStartedAt            DateTime?
  paymentsCustomerId       String?
  locale                   String?
  displayUsername          String?
  anonymized               Boolean                      @default(false)
  twoFactorEnabled         Boolean?
  lastActiveOrganizationId String?
  sessions                 Session[]
  accounts                 Account[]
  passkeys                 Passkey[]
  invitations              Invitation[]
  purchases                Purchase[]
  members                  Member[]
  twofactors               TwoFactor[]
  notifications            Notification[]
  notificationPreferences  UserNotificationPreference[]
  aiWallet                 AiWallet?
  knowledgeSpaces          KnowledgeSpace[]
  npsSurveyResponses       NpsSurveyResponse[]
  assistantConversations   AssistantConversation[]
  auditLogs                AuditLog[]
  deletionRequests         UserDeletionRequest[]

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  activeOrganizationId String?

  token     String
  createdAt DateTime
  updatedAt DateTime

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id           String    @id @default(cuid())
  accountId    String
  providerId   String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String?   @db.Text
  refreshToken String?   @db.Text
  idToken      String?   @db.Text
  expiresAt    DateTime?
  password     String?

  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime
  updatedAt             DateTime

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String   @db.Text
  expiresAt  DateTime

  createdAt DateTime?
  updatedAt DateTime?

  @@index([identifier])
  @@map("verification")
}

model Passkey {
  id           String    @id @default(cuid())
  name         String?
  publicKey    String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialID String
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  aaguid       String?
  createdAt    DateTime?

  @@index([userId])
  @@index([credentialID])
  @@map("passkey")
}

model TwoFactor {
  id          String @id @default(cuid())
  secret      String
  backupCodes String
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("twoFactor")
}

model Organization {
  id                   String                   @id @default(cuid())
  name                 String
  slug                 String?
  logo                 String?
  createdAt            DateTime
  trialEndsAt          DateTime?
  metadata             String?
  paymentsCustomerId   String?
  storageRegion        String                   @default("eu")
  members              Member[]
  invitations          Invitation[]
  purchases            Purchase[]
  searchIndexes        SearchIndex[]
  searchApiKeys        SearchApiKey[]
  searchUsageEvents    SearchUsageEvent[]
  searchIngestBuffer   SearchIngestBuffer[]
  connectorSyncJobs    SearchConnectorSyncJob[]
  shopifyStores        ShopifyStore[]
  aiWallet             AiWallet?
  knowledgeSpaces      KnowledgeSpace[]
  activationEvents     ActivationEvent[]
  collections          Collection[]
  collectionDocuments  CollectionDocument[]
  npsSurveyResponses   NpsSurveyResponse[]
  featureFlagOverrides        FeatureFlagOverride[]
  assistantConversations      AssistantConversation[]
  auditLogs                   AuditLog[]
  scimConfiguration           ScimConfiguration?
  scimAuditLogs               ScimAuditLog[]
  scimProvisioningRules       ScimProvisioningRule[]
  searchIndexSynonyms         SearchIndexSynonym[]
  globalSynonymSets           GlobalSynonymSet[]
  globalSynonymSetCollections GlobalSynonymSetCollection[]

  @@unique([slug])
  @@map("organization")
}

model Member {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String
  createdAt      DateTime

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

enum PurchaseType {
  SUBSCRIPTION
  ONE_TIME
}

model Purchase {
  id             String        @id @default(cuid())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String?
  type           PurchaseType
  customerId     String
  subscriptionId String?       @unique
  priceId        String
  status         String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([subscriptionId])
  @@map("purchase")
}

enum NotificationTarget {
  IN_APP
  EMAIL
}

enum NotificationType {
  WELCOME
  APP_UPDATE
  AI_LOW_BALANCE
  AI_TOPUP_PAID
  AI_TOPUP_FAILED
  AI_OVERAGE_REACHED
  PAYMENT_FAILED
  QUOTA_ALERT
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  data      Json             @default("{}")
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId])
  @@map("notification")
}

model UserNotificationPreference {
  id        String             @id @default(cuid())
  userId    String
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  target    NotificationTarget
  createdAt DateTime           @default(now())

  @@unique([userId, type, target])
  @@map("user_notification_preference")
}

model SearchIndex {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slug           String
  displayName    String
  schema         Json
  version        Int          @default(1)
  enabled        Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  apiKeys       SearchApiKey[]
  usageEvents   SearchUsageEvent[]
  ingestBuffer  SearchIngestBuffer[]
  syncJobs      SearchConnectorSyncJob[]
  shopifyStores        ShopifyStore[]
  searchIndexSynonyms  SearchIndexSynonym[]
  excludedFromGlobalSynonymSets GlobalSynonymSetCollection[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("search_index")
}

model SearchIndexSynonym {
  id             String       @id @default(cuid())
  indexId        String
  index          SearchIndex  @relation(fields: [indexId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  root           String
  synonym        String
  locale         String?      @default("en")
  type           String       @default("synonym")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([indexId, root, synonym])
  @@index([indexId])
  @@index([organizationId])
  @@map("search_index_synonym")
}

model GlobalSynonymSet {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  root           String
  synonyms       String[]
  locale         String?      @default("en")
  scope          String       @default("all") // "all" or "selected"
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  excludedCollections GlobalSynonymSetCollection[]

  @@index([organizationId])
  @@map("global_synonym_set")
}

model GlobalSynonymSetCollection {
  id             String           @id @default(cuid())
  synonymSetId   String
  synonymSet     GlobalSynonymSet @relation(fields: [synonymSetId], references: [id], onDelete: Cascade)
  indexId        String
  index          SearchIndex      @relation(fields: [indexId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([synonymSetId, indexId])
  @@index([indexId])
  @@index([organizationId])
  @@map("global_synonym_set_collection")
}

model SearchApiKey {
  id                 String       @id @default(cuid())
  indexId            String
  index              SearchIndex  @relation(fields: [indexId], references: [id], onDelete: Cascade)
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name               String
  prefix             String
  hash               String       @unique
  scopes             String[]
  allowedOrigins     String[]     @default([])
  rateLimitPerMinute Int          @default(600)
  expiresAt          DateTime?
  revokedAt          DateTime?
  lastUsedAt         DateTime?
  createdAt          DateTime     @default(now())

  @@index([indexId])
  @@index([organizationId])
  @@map("search_api_key")
}

model SearchRateLimitBucket {
  keyId       String
  windowStart DateTime
  count       Int      @default(0)

  @@id([keyId, windowStart])
  @@index([windowStart])
  @@map("search_rate_limit_bucket")
}

model SearchUsageEvent {
  id             String       @id @default(cuid())
  indexId        String
  index          SearchIndex  @relation(fields: [indexId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String
  count          Int          @default(1)
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([indexId, createdAt])
  @@map("search_usage_event")
}

model SearchIngestBuffer {
  id             String       @id @default(cuid())
  indexId        String
  index          SearchIndex  @relation(fields: [indexId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  action         String
  document       Json
  processedAt    DateTime?
  attempts       Int          @default(0)
  lastError      String?
  nextRetryAt    DateTime?
  createdAt      DateTime     @default(now())

  @@index([indexId, processedAt, nextRetryAt])
  @@map("search_ingest_buffer")
}

model SearchConnectorSyncJob {
  id             String       @id @default(cuid())
  indexId        String
  index          SearchIndex  @relation(fields: [indexId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           String
  status         String
  startedAt      DateTime     @default(now())
  finishedAt     DateTime?
  durationMs     Int?
  itemsCount     Int          @default(0)
  failuresCount  Int          @default(0)
  lastError      String?
  events         Json         @default("[]")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, startedAt(sort: Desc)])
  @@index([indexId, startedAt(sort: Desc)])
  @@map("search_connector_sync_job")
}

model ShopifyStore {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  indexId        String?
  index          SearchIndex? @relation(fields: [indexId], references: [id], onDelete: SetNull)
  shop           String       @unique // myshop.myshopify.com
  accessToken    String // AES-256-GCM encrypted at rest
  scopes         String       @default("")
  name           String?
  email          String?
  domain         String?
  installedAt    DateTime     @default(now())
  uninstalledAt  DateTime?
  lastSyncAt     DateTime?
  syncStatus     String       @default("pending") // pending, syncing, active, error, uninstalled
  syncError      String?
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([syncStatus])
  @@map("shopify_store")
}

enum KnowledgeOwnerType {
  USER
  ORGANIZATION
}

enum KnowledgeSourceType {
  CMS_PRESTASHOP
  CMS_BITRIX
  FILE_MD
  FILE_XML
  FILE_PDF
  FILE_DOCX
  FILE_XLSX
  FILE_PPTX
  FILE_EPUB
  FILE_IMG
  FILE_AUDIO
  FILE_VIDEO
  FILE_CSV
  FILE_JSON
  FILE_TXT
  HTTP_SITEMAP
  RSS
}

enum IngestionJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

model KnowledgeSpace {
  id             String              @id @default(cuid())
  ownerType      KnowledgeOwnerType
  userId         String?
  user           User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slug           String
  name           String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  dataSources    DataSource[]
  documents      KnowledgeDocument[]
  chunks         KnowledgeChunk[]
  graphNodes     GraphNode[]
  graphEdges     GraphEdge[]
  ingestionJobs  IngestionJob[]

  @@unique([ownerType, userId, slug])
  @@unique([ownerType, organizationId, slug])
  @@index([ownerType, userId])
  @@index([ownerType, organizationId])
  @@map("knowledge_space")
}

model DataSource {
  id               String              @id @default(cuid())
  knowledgeSpaceId String
  knowledgeSpace   KnowledgeSpace      @relation(fields: [knowledgeSpaceId], references: [id], onDelete: Cascade)
  sourceType       KnowledgeSourceType
  name             String
  config           Json                @default("{}")
  credentialRef    String?
  syncEnabled      Boolean             @default(true)
  lastSyncedAt     DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  ingestionJobs    IngestionJob[]
  documents        KnowledgeDocument[]

  @@index([knowledgeSpaceId, sourceType])
  @@map("data_source")
}

model IngestionJob {
  id               String             @id @default(cuid())
  knowledgeSpaceId String
  knowledgeSpace   KnowledgeSpace     @relation(fields: [knowledgeSpaceId], references: [id], onDelete: Cascade)
  dataSourceId     String?
  dataSource       DataSource?        @relation(fields: [dataSourceId], references: [id], onDelete: SetNull)
  status           IngestionJobStatus @default(QUEUED)
  mode             String
  inputMeta        Json               @default("{}")
  totalItems       Int                @default(0)
  processedItems   Int                @default(0)
  failedItems      Int                @default(0)
  errorMessage     String?
  startedAt        DateTime?
  finishedAt       DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([knowledgeSpaceId, status, createdAt(sort: Desc)])
  @@index([dataSourceId, createdAt(sort: Desc)])
  @@map("ingestion_job")
}

model KnowledgeDocument {
  id               String              @id @default(cuid())
  knowledgeSpaceId String
  knowledgeSpace   KnowledgeSpace      @relation(fields: [knowledgeSpaceId], references: [id], onDelete: Cascade)
  dataSourceId     String?
  dataSource       DataSource?         @relation(fields: [dataSourceId], references: [id], onDelete: SetNull)
  externalId       String
  sourceType       KnowledgeSourceType
  title            String
  mimeType         String
  language         String              @default("en")
  contentText      String
  metadata         Json                @default("{}")
  version          Int                 @default(1)
  checksum         String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  chunks           KnowledgeChunk[]

  @@unique([knowledgeSpaceId, externalId])
  @@index([knowledgeSpaceId, sourceType, updatedAt(sort: Desc)])
  @@map("knowledge_document")
}

model KnowledgeChunk {
  id               String            @id @default(cuid())
  knowledgeSpaceId String
  knowledgeSpace   KnowledgeSpace    @relation(fields: [knowledgeSpaceId], references: [id], onDelete: Cascade)
  documentId       String
  document         KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chunkIndex       Int
  text             String
  tokenCount       Int               @default(0)
  embedding        Json?
  metadata         Json              @default("{}")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([documentId, chunkIndex])
  @@index([knowledgeSpaceId, documentId])
  @@map("knowledge_chunk")
}

model GraphNode {
  id               String         @id @default(cuid())
  knowledgeSpaceId String
  knowledgeSpace   KnowledgeSpace @relation(fields: [knowledgeSpaceId], references: [id], onDelete: Cascade)
  canonicalName    String
  nodeType         String
  metadata         Json           @default("{}")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([knowledgeSpaceId, canonicalName, nodeType])
  @@index([knowledgeSpaceId, nodeType])
  @@map("graph_node")
}

model GraphEdge {
  id               String         @id @default(cuid())
  knowledgeSpaceId String
  knowledgeSpace   KnowledgeSpace @relation(fields: [knowledgeSpaceId], references: [id], onDelete: Cascade)
  fromNodeId       String
  toNodeId         String
  relationType     String
  weight           Float          @default(1)
  evidenceChunkId  String?
  metadata         Json           @default("{}")
  createdAt        DateTime       @default(now())

  @@index([knowledgeSpaceId, fromNodeId, relationType])
  @@index([knowledgeSpaceId, toNodeId, relationType])
  @@map("graph_edge")
}

// ─────────────────────────────────────────────────────────────────────────────
// AI Wallet + Usage Ledger + RUB Top-up
// XOR ownership (user OR organization) mirrors Purchase pattern.
// XOR is enforced via SQL CHECK constraint added in the SQL migration step.
// All money is stored as integer minor units (kopecks) — never numeric.
// ─────────────────────────────────────────────────────────────────────────────

model AiWallet {
  id             String        @id @default(cuid())
  userId         String?       @unique
  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?       @unique
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  currency                    String @default("RUB")
  availableBalanceKopecks     BigInt @default(0)
  reservedBalanceKopecks      BigInt @default(0)
  includedMonthlyLimitKopecks BigInt @default(0)
  includedUsedPeriodKopecks   BigInt @default(0)
  promoBalanceKopecks         BigInt @default(0)
  overageLimitKopecks         BigInt @default(0)
  overageUsedKopecks          BigInt @default(0)

  // ── Auto-Recharge Config ──
  autoRechargeEnabled          Boolean @default(false)
  autoRechargeThresholdKopecks BigInt  @default(100000) // $10 in kopecks
  autoRechargeAmountKopecks    BigInt  @default(500000) // $50 in kopecks

  status      String   @default("active") // active | frozen | closed
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  transactions AiWalletTransaction[]
  reservations AiQuotaReservation[]
  usageEvents  AiUsageEvent[]
  topupOrders  WalletTopupOrder[]

  @@index([periodEnd, status])
  @@map("ai_wallet")
}

model AiWalletTransaction {
  id             String   @id @default(cuid())
  walletId       String
  wallet         AiWallet @relation(fields: [walletId], references: [id], onDelete: Restrict)
  userId         String?
  organizationId String?
  projectId      String?
  type           String // reserve | release | debit | credit | reversal | adjustment
  direction      String // credit | debit | reserve | release | reversal
  amountKopecks  BigInt
  currency       String   @default("RUB")
  source         String // included | promo | prepaid | overage | tochka | manual | reservation
  usageEventId   String?
  reservationId  String?
  topupOrderId   String?
  idempotencyKey String   @unique
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([walletId, createdAt(sort: Desc)])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([usageEventId])
  @@index([topupOrderId])
  @@map("ai_wallet_transaction")
}

model AiQuotaReservation {
  id                     String    @id @default(cuid())
  walletId               String
  wallet                 AiWallet  @relation(fields: [walletId], references: [id], onDelete: Restrict)
  userId                 String?
  organizationId         String?
  projectId              String?
  apiKeyId               String?
  operation              String
  estimatedAmountKopecks BigInt
  status                 String    @default("active") // active | committed | released | expired
  expiresAt              DateTime
  committedAt            DateTime?
  releasedAt             DateTime?
  metadata               Json?
  createdAt              DateTime  @default(now())

  @@index([status, expiresAt])
  @@index([walletId, status])
  @@map("ai_quota_reservation")
}

model AiUsageEvent {
  id                    String   @id @default(cuid())
  walletId              String
  wallet                AiWallet @relation(fields: [walletId], references: [id], onDelete: Restrict)
  userId                String?
  organizationId        String?
  projectId             String?
  apiKeyId              String?
  reservationId         String?
  operation             String
  provider              String
  model                 String
  status                String
  promptTokens          Int      @default(0)
  completionTokens      Int      @default(0)
  totalTokens           Int      @default(0)
  inputCostKopecks      BigInt   @default(0)
  outputCostKopecks     BigInt   @default(0)
  flatFeeKopecks        BigInt   @default(0)
  markupBps             Int      @default(0)
  totalChargeKopecks    BigInt   @default(0)
  providerCostUsdMicros BigInt   @default(0)
  fxRateRubPerUsdMicros BigInt   @default(0)
  pricingRuleId         String?
  requestId             String?
  idempotencyKey        String   @unique
  metadata              Json?
  createdAt             DateTime @default(now())

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([projectId, operation, createdAt])
  @@index([model, provider, createdAt])
  @@map("ai_usage_event")
}

model AiPricingRule {
  id                          String    @id @default(cuid())
  provider                    String
  model                       String
  operation                   String
  currency                    String    @default("RUB")
  inputPer1MTokensKopecks     BigInt?
  outputPer1MTokensKopecks    BigInt?
  embeddingPer1MTokensKopecks BigInt?
  flatFeeKopecks              BigInt    @default(0)
  markupBps                   Int       @default(2000)
  effectiveFrom               DateTime
  effectiveTo                 DateTime?
  notes                       String?
  createdByUserId             String?
  createdAt                   DateTime  @default(now())

  @@unique([provider, model, operation, effectiveFrom])
  @@index([provider, model, operation, effectiveFrom, effectiveTo])
  @@map("ai_pricing_rule")
}

model FxRate {
  id                 String   @id @default(cuid())
  pair               String
  ratePer1UnitMicros BigInt
  source             String
  effectiveAt        DateTime
  createdAt          DateTime @default(now())

  @@index([pair, effectiveAt(sort: Desc)])
  @@map("fx_rate")
}

model WalletTopupOrder {
  id                  String    @id @default(cuid())
  walletId            String
  wallet              AiWallet  @relation(fields: [walletId], references: [id], onDelete: Restrict)
  userId              String?
  organizationId      String?
  provider            String // tochka | dodo | manual
  amountKopecks       BigInt
  currency            String    @default("RUB")
  status              String    @default("created") // created | pending | paid | failed | cancelled | expired | refunded
  paymentLinkUrl      String?
  providerPaymentId   String?
  providerOperationId String?   @unique
  providerCustomerId  String?
  initiatedByUserId   String?
  idempotencyKey      String    @unique
  metadata            Json?
  expiresAt           DateTime?
  paidAt              DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([organizationId, status, createdAt(sort: Desc)])
  @@index([userId, status, createdAt(sort: Desc)])
  @@index([provider, status])
  @@map("wallet_topup_order")
}

model PaymentProviderEvent {
  id              String    @id @default(cuid())
  provider        String
  eventType       String
  providerEventId String?
  signatureValid  Boolean   @default(false)
  rawPayload      Json
  idempotencyKey  String    @unique
  topupOrderId    String?
  processedAt     DateTime?
  processingError String?
  createdAt       DateTime  @default(now())

  @@index([provider, createdAt(sort: Desc)])
  @@index([processedAt])
  @@map("payment_provider_event")
}

// ─── Activation milestones ──────────────────────────────────────
// Track onboarding funnel progress for each organization.
// XOR ownership (user OR organization) mirrors Purchase pattern.

// ─── Roadmap items ─────────────────────────────────────────────
// Public roadmap items for the marketing site. Stores canonical EN data;
// localized titles/descriptions remain in i18n.

enum RoadmapItemStatus {
  shipped
  inProgress
  planned
}

model RoadmapItem {
  id            String            @id @default(cuid())
  key           String            @unique
  title         String
  description   String
  status        RoadmapItemStatus
  quarter       String
  iconName      String
  voteCount     Int               @default(0)
  sortOrder     Int               @default(0)
  changelogSlug String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("roadmap_item")
}

model ActivationEvent {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventType      String // EMAIL_VERIFIED, FIRST_COLLECTION, FIRST_DOCUMENT, FIRST_SEARCH, WIDGET_EMBEDDED, FIRST_TEAM_MEMBER, FIRST_INTEGRATION, FIRST_PAYMENT
  completedAt    DateTime     @default(now())
  metadata       Json?

  @@unique([organizationId, eventType])
  @@index([organizationId])
  @@map("activation_event")
}

// ─── Collections & Documents ─────────────────────────────────────────────
// Manage data in spreadsheet-like interface (Airtable/Excel style).
// Collections belong to an organization and contain documents with flexible JSON data.

model Collection {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slug           String
  name           String
  description    String?
  schema         Json                 @default("[]") // Array of field definitions
  documentCount  Int                  @default(0)
  size           BigInt               @default(0)
  status         String               @default("active") // active | archived
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  documents      CollectionDocument[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("collection")
}

model CollectionDocument {
  id             String       @id @default(cuid())
  collectionId   String
  collection     Collection   @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  data           Json         @default("{}") // Flexible document fields
  rowNumber      Int // Sequential row number within collection
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([collectionId, rowNumber])
  @@index([collectionId, createdAt(sort: Desc)])
  @@index([organizationId])
  @@map("collection_document")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("roadmap_vote")
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@map("newsletter_subscriber")
}

model NpsSurveyResponse {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  score          Int // 0-10
  feedback       String? // Optional follow-up text
  source         String // "in_app" | "email" | "support"
  createdAt      DateTime      @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([createdAt(sort: Desc)])
  @@map("nps_survey_response")
}

// Audit log for tracking user actions across the platform.
// Used by the audit-log API module for per-organization action tracking.
model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  action         String   // e.g. "create_index", "update_rules", "add_member"
  targetType     String?  // e.g. "index", "api_key", "member"
  targetId       String?
  details        Json?    // Flexible payload with action-specific context
  ipAddress      String?
  userAgent      String?

  createdAt DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_log")
}

// Internal feature flag system for gradual rollout (AAC-176 EPIC).
// Flags are global; overrides are per-organization.

model FeatureFlag {
  id          String  @id @default(cuid())
  key         String  @unique // e.g. "analytics-v2", "knowledge-rag"
  title       String // Human-readable name
  description String? // What this flag controls

  type String @default("boolean") // "boolean" | "variant"

  // Boolean mode: enabled/disabled for all matching targets
  enabled Boolean @default(false) // Global default

  // Variant mode: returns one of variantValues
  variantValues  String[] // e.g. ["control", "treatment-a", "treatment-b"]
  variantDefault String? // Fallback variant

  // % rollout
  rolloutPercentage Int? // 0-100: % of matched tenants that get enabled=true

  // Targeting rules (JSON — flexible, parsed at runtime)
  // Rules are AND-combined. Each rule: { field: "planTier" | "orgAge" | "geo" | "orgSlug" | "manualList", operator: "in" | "notIn" | "gte" | "lt", value: string | string[] }
  targetingRules Json? // Prisma.Json, cast as Record<string, unknown>

  // Kill switch — when true, force-disables for ALL orgs regardless of overrides
  killSwitch Boolean @default(false)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String? // Agent ID or user ID

  overrides FeatureFlagOverride[]
  auditLogs FeatureFlagAuditLog[]

  @@map("feature_flag")
}

model FeatureFlagOverride {
  id             String       @id @default(cuid())
  flagId         String
  flag           FeatureFlag  @relation(fields: [flagId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  enabled        Boolean // For boolean flags

  // For variant flags
  variantValue String?

  // Override reason
  reason String?

  @@unique([flagId, organizationId])
  @@index([organizationId])
  @@map("feature_flag_override")
}

// ─────────────────────────────────────────────────────────────────────────────
// Assistant Conversations & Messages
// Persistent storage for the Conversational AI Assistant (chat mode widget).
// Supports anonymous users (sessionId) and authenticated users (userId).
// ─────────────────────────────────────────────────────────────────────────────

model AssistantConversation {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId      String
  mode           String             @default("product_consultation")
  entryPoint     String?
  status         String             @default("active")
  startedAt      DateTime           @default(now())
  lastMessageAt  DateTime           @updatedAt
  resolvedAt     DateTime?
  escalatedAt    DateTime?
  messageCount   Int                @default(0)
  metadata       Json               @default("{}")
  messages       AssistantMessage[]

  @@index([organizationId, userId])
  @@index([organizationId, sessionId])
  @@index([organizationId, status, lastMessageAt(sort: Desc)])
  @@map("assistant_conversation")
}

model AssistantMessage {
  id             String                 @id @default(cuid())
  conversationId String
  conversation   AssistantConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String                 @db.Text
  toolName       String?
  toolCalls      Json?
  citations      Json?
  latencyMs      Int?
  inputTokens    Int?
  outputTokens   Int?
  createdAt      DateTime               @default(now())

  @@index([conversationId, createdAt])
  @@map("assistant_message")
}

// Audit log for feature flag changes (AAC-880)
// Records every create, update, delete, and override change for admin review.
model FeatureFlagAuditLog {
  id             String   @id @default(cuid())
  flagId         String
  flag           FeatureFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)

  // What action was performed
  action         String   // "created" | "updated" | "deleted" | "override_set" | "override_removed"
  field          String?  // Which field changed: "enabled", "killSwitch", "rolloutPercentage", "title", "description", "targetingRules", etc.
  oldValue       String?  // Previous value (serialized — null for creates)
  newValue       String?  // New value (serialized — null for deletes)

  // Who did it
  performedById String? // User ID or agent ID
  performedByType String @default("user") // "user" | "agent"

  // For override-related changes, the affected organization
  organizationId String?

  createdAt DateTime @default(now())

  @@index([flagId])
  @@index([flagId, createdAt])
  @@index([createdAt])
  @@map("feature_flag_audit_log")
}

// ── SCIM 2.0 Configuration ─────────────────────────────────────────────

// SCIM IdP connection configuration per organization
model ScimConfiguration {
  id             String   @id @default(cuid())
  organizationId String   @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Identity provider type
  provider       String   @default("other")

  // Bearer token hash (sha256 hex) — hash-once pattern like SearchApiKey
  // Only the prefix is stored for display; raw token is shown once at creation
  bearerTokenHash    String   @unique
  bearerTokenPrefix  String

  // Sync status
  syncEnabled    Boolean  @default(false)
  lastSyncAt     DateTime?
  lastSyncStatus String?

  // Custom provider endpoint URL
  endpointUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@map("scim_configuration")
}

// Audit log for SCIM provisioning actions
model ScimAuditLog {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Action: config_created, config_updated, config_deleted, token_regenerated,
  // test_connection, sync_started, sync_completed, sync_failed,
  // user_provisioned, user_deprovisioned, group_provisioned
  action         String

  // Target of the action (e.g. "config", "user:userId", "group:groupId")
  target         String?

  // Result
  success        Boolean  @default(true)

  // Details — error messages, counts, etc. (serialized JSON)
  details        String?

  // Who triggered it
  performedBy    String?
  ipAddress      String?

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("scim_audit_log")
}

// SCIM provisioning rules: maps IdP groups to organization roles
// Each rule defines a group name from the identity provider and the target role
// to assign in AACSearch, plus what happens on deprovisioning.
model ScimProvisioningRule {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // The SCIM group name from the IdP (e.g., "Engineering", "Admins")
  groupName      String

  // The target role in AACSearch (owner, admin, member)
  targetRole     String       @default("member")

  // Deprovisioning action: "suspend" — disable user, "remove" — remove from org, "notify" — alert only
  deprovisionAction String   @default("suspend")

  // Whether this rule is active
  enabled        Boolean      @default(true)

  // Optional description for the rule
  description    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, groupName])
  @@index([organizationId])
  @@map("scim_provisioning_rule")
}

// GDPR: Right to Erasure — tracks deletion requests with grace period
model UserDeletionRequest {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reason            String?
  retentionUntil    DateTime  // 30-day grace period before permanent deletion
  status            String    @default("pending") // pending | approved | cancelled | completed
  cancellationToken String    @unique             // For cancellation within grace period
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status, retentionUntil])
  @@map("user_deletion_request")
}
