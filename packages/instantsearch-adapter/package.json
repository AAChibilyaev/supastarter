{
	"name": "@aacsearch/instantsearch-adapter",
	"version": "0.1.0",
	"description": "AACsearch InstantSearch.js adapter — drop-in replacement for the Algolia search client in the InstantSearch ecosystem",
	"keywords": [
		"aacsearch",
		"adapter",
		"algolia",
		"angular-instantsearch",
		"instantsearch",
		"react-instantsearch",
		"search",
		"vue-instantsearch"
	],
	"homepage": "https://aacsearch.com/docs/sdks/instantsearch",
	"bugs": "https://github.com/aacsearch/supastarter/issues",
	"license": "MIT",
	"author": "AACSearch (https://aacsearch.com)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/aacsearch/supastarter.git",
		"directory": "packages/instantsearch-adapter"
	},
	"files": [
		"src"
	],
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"build": "tsc",
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"prepublishOnly": "pnpm build",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@aacsearch/client": "workspace:*"
	},
	"devDependencies": {
		"@repo/tsconfig": "workspace:*",
		"@types/node": "catalog:",
		"typescript": "catalog:"
	},
	"peerDependencies": {
		"instantsearch.js": "^4.0.0"
	},
	"engines": {
		"node": ">= 20"
	}
}
