{
	"name": "@aacsearch/kinesis-sync",
	"version": "0.1.0",
	"description": "AWS Kinesis streaming connector for AACsearch — consume Kinesis Data Streams and sync documents to AACsearch Engine with checkpointing, at-least-once delivery, and dead-letter queue",
	"keywords": [
		"aacsearch",
		"aws",
		"connector",
		"kinesis",
		"search",
		"streaming",
		"sync"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/nousresearch/aacsearch.git"
	},
	"files": [
		"dist",
		"README.md"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"build": "tsc",
		"type-check": "tsc --noEmit",
		"prepublish": "pnpm build"
	},
	"dependencies": {
		"@aws-sdk/client-kinesis": "^3.1041.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"typescript": "^6.0.0"
	}
}
