# AACsearch Performance Baselines
# Update these values after establishing a known-good deployment baseline.
# CI regression gate: fails if p99 > baseline * 1.2
#
# To update: run the benchmark against a known-good deployment and extract:
#   k6 run scenarios/search-benchmark.js --out json=/tmp/report.json
#   jq '.metrics.http_req_duration.values."p(99)"' /tmp/report.json

# Search benchmark — p99 latency at 1K RPS (target: <100ms)
SEARCH_P99_BASELINE_MS=85

# Ingest benchmark — p95 latency at 100K docs/min (target: <2s)
INGEST_P95_BASELINE_MS=1200

# Widget benchmark — p99 latency at 500 concurrent sessions (target: <200ms)
WIDGET_P99_BASELINE_MS=150
