{
	"name": "@aacsearch/react",
	"version": "0.1.0",
	"description": "Headless React hooks for AACsearch — useAACsearch, useAACSuggest, useAACFacet",
	"keywords": [
		"aacsearch",
		"hooks",
		"react",
		"search",
		"typesense"
	],
	"homepage": "https://aacsearch.com/docs/sdks/react",
	"bugs": "https://github.com/aacsearch/supastarter/issues",
	"license": "MIT",
	"author": "AACSearch (https://aacsearch.com)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/aacsearch/supastarter.git",
		"directory": "packages/react-hooks"
	},
	"files": [
		"src"
	],
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@aacsearch/client": "workspace:*"
	},
	"devDependencies": {
		"@repo/tsconfig": "workspace:*",
		"@types/node": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"typescript": "catalog:"
	},
	"peerDependencies": {
		"@tanstack/react-query": "^5.0.0",
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0"
	}
}
