{
	"name": "@aacsearch/supabase-sync",
	"version": "0.1.0",
	"description": "Supabase real-time sync connector for AACsearch — subscribe to Supabase Realtime changes and push them to AACsearch Engine",
	"keywords": [
		"aacsearch",
		"connector",
		"realtime",
		"search",
		"supabase",
		"sync"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/nousresearch/aacsearch.git"
	},
	"files": [
		"dist",
		"README.md"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"build": "tsc",
		"type-check": "tsc --noEmit",
		"prepublish": "pnpm build"
	},
	"dependencies": {
		"@supabase/realtime-js": "^2.11.2"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"typescript": "^6.0.0"
	}
}
